# Copier ce fichier en .env.local et renseigner les valeurs réelles.
# .env.local n'est jamais versionné (voir .gitignore).

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — génération de contenu et brouillons d'emails (phase 6)
ANTHROPIC_API_KEY=

# Stripe — abonnements (phase 8)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID récurrents (mensuels)
STRIPE_PRICE_STUDIO_AUTOMATIZZATO=
STRIPE_PRICE_STUDIO_360=
STRIPE_PRICE_PRESENZA_ONLINE=
# Price ID one-time (forfait de mise en place), optionnels
STRIPE_PRICE_STUDIO_AUTOMATIZZATO_SETUP=
STRIPE_PRICE_STUDIO_360_SETUP=
STRIPE_PRICE_PRESENZA_ONLINE_SETUP=

# URL publique de l'app (ajuster selon l'environnement de déploiement
# tant que automa-ia.net n'est pas reconnecté, cf. cahier des charges §5/§9)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret du cron de récurrence des tâches (Workflow > Modelli), voir vercel.json.
# Vercel envoie automatiquement "Authorization: Bearer <valeur>" à chaque exécution
# planifiée si cette variable est définie sur le projet.
CRON_SECRET=

# Bozze email — inoltro automatico via Mailgun (Routes), voir README §Bozze email
# Domaine géré par Mailgun pour recevoir les emails transférés par les clients.
INBOUND_EMAIL_DOMAIN=in.freelancerai.eu
# Clé de signature Mailgun (Account > Security), pour vérifier l'authenticité des webhooks.
MAILGUN_WEBHOOK_SIGNING_KEY=
